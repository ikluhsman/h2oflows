# Database — required
DATABASE_URL=postgres://h2oflow:changeme@localhost:5432/h2oflow?sslmode=disable

# AI services — required for RAG river assistant and search enrichment
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...

# Server
APP_PORT=8080
APP_NAME=H2OFlows
APP_DOMAIN=h2oflows.app

# Gauge polling intervals (Go duration syntax: 15m, 1h, etc.)
USGS_POLL_INTERVAL=15m
DWR_POLL_INTERVAL=15m

# Optional
USGS_API_KEY=
JWT_SECRET=
