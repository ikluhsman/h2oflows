# Application
APP_NAME=H2OFlow
APP_DOMAIN=localhost
APP_PORT=8080

# Database (matches docker-compose.yml defaults)
POSTGRES_USER=h2oflow
POSTGRES_PASSWORD=h2oflow
POSTGRES_DB=h2oflow
DATABASE_URL=postgres://h2oflow:h2oflow@localhost:5432/h2oflow?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# Gauge polling intervals (Go duration format)
USGS_POLL_INTERVAL=15m
DWR_POLL_INTERVAL=15m
